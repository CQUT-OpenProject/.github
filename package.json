{
  "name": "cqut-osp-design",
  "version": "0.1.0",
  "private": true,
  "description": "重庆理工大学开源计划的品牌与视觉设计规范",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "pnpm assets:build && pnpm --filter @cqut-openproject/docs dev",
    "build": "pnpm assets:build && pnpm --filter @cqut-openproject/docs build",
    "preview": "pnpm --filter @cqut-openproject/docs preview",
    "assets:build": "node scripts/build-assets.mjs",
    "check": "pnpm format:check && pnpm --filter @cqut-openproject/docs check && pnpm build && linkinator apps/docs/dist --recurse --skip '^http://localhost:4321' --skip '^https://github.com'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm assets:build && vitest run",
    "test:e2e": "playwright test",
    "verify": "pnpm check && pnpm test && pnpm test:e2e"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.1",
    "linkinator": "7.5.3",
    "prettier": "3.6.2",
    "prettier-plugin-astro": "0.14.1",
    "sharp": "0.35.3",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
